        <insert tableName="resenas"><column name="tela_id" value="10"/><column name="usuario_id" value="2"/><column name="calificacion" value="5"/><column name="comentario" value="Compré el tul transparente para una decoración y cumplió perfectamente su propósito."/><column name="fecha_creacion" value="2023-10-12"/></insert>
    </changeSet>

</databaseChangeLog>
